# Local Postgres (matches docker-compose.yml). Copy this file to `.env`.
# If you already run Postgres on 5432, set DB_PORT to a free port (e.g. 5433)
# and match it in DATABASE_URL below. compose reads DB_PORT automatically.
DB_PORT=5432
DATABASE_URL=postgres://fitmore:fitmore@localhost:5432/fitmore

# Optional. If unset, the insight engine produces a $0 rules-based narrative
# instead of calling Claude. Set it to switch on AI-written insights.
# ANTHROPIC_API_KEY=sk-ant-...

# Which model writes the AI insight. Haiku is the cheap default for weekly
# readouts; bump to claude-opus-4-8 for an occasional deep analysis.
INSIGHT_MODEL=claude-haiku-4-5

# How many days of synthetic data the mock adapter generates.
MOCK_DAYS=35
